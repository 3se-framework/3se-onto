{
  "@context": {
    "@version": 1.1,
    "@base": "https://www.3se.info/3se-onto/properties/",

    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "dcterms": "http://purl.org/dc/terms/",
    "foaf": "http://xmlns.com/foaf/0.1/",
    "prov": "http://www.w3.org/ns/prov#",

    "title": "rdfs:label",
    "description": "rdfs:comment",

    "domain":               { "@id": "rdfs:domain",             "@type": "@id" },
    "range":                { "@id": "rdfs:range",              "@type": "@id" },
    "subPropertyOf":        { "@id": "rdfs:subPropertyOf",      "@type": "@id" },
    "isReferencedBy":       { "@id": "dcterms:isReferencedBy",  "@type": "@id" },

    "entryCreated":         { "@id": "dcterms:created",         "@type": "xsd:date" },
    "entryModified":        { "@id": "dcterms:modified",        "@type": "xsd:date" },
    "entryCreator":         { "@id": "dcterms:creator" },
    "entryContributor":     { "@id": "dcterms:contributor" },

    "status":               { "@id": "https://www.3se.info/3se-onto/vocab#status" }
  }
}